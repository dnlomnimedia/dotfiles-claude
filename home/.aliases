# PHP / Laravel
alias phpunit="vendor/bin/phpunit"
alias a="php artisan"
alias c="claude"
alias cy="claude-yolo"
alias cu="composer update"
alias cr="composer require"
alias ci="composer install"
alias cda="composer dump-autoload -o"
alias mfs='php artisan migrate:fresh --seed'
alias nah='git reset --hard;git clean -df'
alias pp="php artisan test --parallel"

# JavaScript / Node
alias jest="./node_modules/.bin/jest"
alias nrd="npm run dev"
alias nrb="npm run build"
alias nr="npm run"

# Git
alias gpo="git push origin"
alias push="git push"
alias pull="git pull"
alias uncommit="git reset --soft HEAD~1"

# Redis
alias flush-redis="redis-cli FLUSHALL"

# Network
alias ip="curl ifconfig.me/ip ; echo"

# Enable aliases to be sudo'ed
alias sudo='sudo '

# Modern CLI tool aliases (conditional on installation)
if command -v eza &> /dev/null; then
    alias ls="eza --icons --group-directories-first"
    alias l="eza -la --icons --group-directories-first --hyperlink"
    alias ll="eza -l --icons --group-directories-first --hyperlink"
    alias lt="eza --tree --level=2 --icons"
fi

if command -v bat &> /dev/null; then
    alias cat="bat --style=plain"
fi

if command -v rg &> /dev/null; then
    alias grep="rg"
fi

if command -v bottom &> /dev/null; then
    alias htop="btm"
    alias top="btm"
fi
