[core]
	excludesfile = ~/.global-gitignore
	autocrlf = false
	pager = delta

[fetch]
	prune = true

[pull]
	rebase = false

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
