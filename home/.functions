# Run Pest or PHPUnit (auto-detects)
function p() {
   if [ -f vendor/bin/pest ]; then
      vendor/bin/pest "$@"
   else
      vendor/bin/phpunit "$@"
   fi
}

# Run tests filtered by name
function pf() {
   if [ -f vendor/bin/pest ]; then
      vendor/bin/pest --filter "$@"
   else
      vendor/bin/phpunit --filter "$@"
   fi
}

# Create a new directory and enter it
function mkd() {
   mkdir -p "$@" && cd "$@"
}

# All DNS info for a domain
function digga() {
    dig +nocmd "$1" any +multiline +noall +answer
}

# Remove a host from known_hosts
function removehost() {
   ssh-keygen -R "$1"
}

# Stage everything and commit — generates message via Claude if none given
function commit() {
  commitMessage="$*"

  git add .

  if [ "$commitMessage" = "" ]; then
     # Start spinner in background
     {
       spinner="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
       while true; do
         for (( i=0; i<${#spinner}; i++ )); do
           printf "\r${spinner:$i:1} Generating commit message..."
           sleep 0.1
         done
       done
     } &!
     spinner_pid=$!

     cleanup() {
       { kill $spinner_pid; wait $spinner_pid; } 2>/dev/null
       printf "\r\033[K"
       trap - INT
       return 1
     }
     trap cleanup INT

     diff_input=$(echo "=== Summary ===" && git diff --cached --stat && echo -e "\n=== Diff (truncated if large) ===" && git diff --cached | head -c 50000)
     commitMessage=$(echo "$diff_input" | claude -p "Write a single-line commit message for this diff. Output ONLY the message, no quotes, no explanation, no markdown.")

     trap - INT
     { kill $spinner_pid; wait $spinner_pid; } 2>/dev/null
     printf "\r\033[K"

     git commit -m "$commitMessage"
     return
  fi

  eval "git commit -a -m '${commitMessage}'"
}

# MySQL database management — connects to DB_HOST (defaults to 'db' for devcontainer)
function db() {
    local host="${DB_HOST:-db}"
    case "$1" in
        refresh)
            mysql -uroot -h "$host" -e "drop database $2; create database $2"
            ;;
        create)
            mysql -uroot -h "$host" -e "create database $2"
            ;;
        drop)
            mysql -uroot -h "$host" -e "drop database $2"
            ;;
        list)
            mysql -uroot -h "$host" -e "show databases" | sed 's/[|[:space:]]//g'
            ;;
        *)
            echo "Usage: db {refresh|create|drop|list} [database_name]"
            return 1
            ;;
    esac
}

# Run Laravel scheduler in a loop (alternative to composer dev)
function scheduler() {
   while :; do
      php artisan schedule:run
      echo "Sleeping 60 seconds..."
      sleep 60
   done
}

# Claude Code with all permissions skipped
function claude-yolo() {
  claude --dangerously-skip-permissions "$@"
}

# Delete local branches whose remote tracking branch is gone
function git-prune-local() {
  git fetch -p && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -D
}

# Clone a GitHub repo via gh
function clone() {
  gh repo clone "$1" "${@:2}"
}
